# NeuralBrief Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# Database (PostgreSQL or SQLite)
DATABASE_URL=postgresql://user:password@localhost:5432/neuralbrief
# Or for SQLite (default):
# DATABASE_URL=sqlite:///./neuralbrief.db

# Scraping & Newsletter window (hours)
SCRAPE_WINDOW_HOURS=48

# SMTP / Email (for sending newsletter)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password

# Newsletter recipient
NEWSLETTER_FROM_EMAIL=your_email@gmail.com
NEWSLETTER_TO_EMAIL=recipient@example.com

# OpenAI (for Digest summaries)
OPENAI_API_KEY=sk-your-openai-api-key

# Optional: Proxy for YouTube scraper (if needed)
# WEBSHARE_USERNAME=
# WEBSHARE_PASSWORD=
